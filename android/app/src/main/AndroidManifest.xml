<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Phase 7.3 (Health Connect bridge, see README): Health
                 Connect requires every app requesting health permissions to
                 handle a "why does this app want this data" rationale,
                 Android 14+ via VIEW_PERMISSION_USAGE, Android 13 and below
                 via the androidx.health rationale action. Both point at
                 this same MainActivity (single-activity app, no separate
                 privacy-policy screen); opening it shows the Settings
                 view's "Health & fitness sync" section (Phase 7.4), which
                 is the actual in-app explanation. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Phase 7.3 (Health Connect bridge, see README): read-only, this
         app only ever consumes Steps (Mi Fitness)/Nutrition (Samsung
         Health) data those apps already synced into Health Connect, never
         writes its own, so there's no corresponding WRITE_* permission. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_NUTRITION" />

    <!-- Package-visibility (Android 11+, API 30+): lets HealthSyncPlugin
         detect whether the Health Connect app itself is installed, to
         distinguish "not installed" from "permission not granted yet"
         (README's Phase 7.3 "Open risks" note). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>
</manifest>
